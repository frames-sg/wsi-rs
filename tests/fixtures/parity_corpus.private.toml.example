# Developer-local parity corpus. NEVER commit this file with real paths.
# Copy to `parity_corpus.private.toml` and fill in `path = ...` for each slide.

# [[slide]]
# name             = "philips_tiff_brightfield_typical"
# alias            = "philips-tiff-local-001"
# path             = "/absolute/local/path/to/slide.tiff"
# format           = "philips_tiff"
# codecs           = ["jpeg"]
# must_decode      = ["base"]
# source           = "local-private"
# license          = "unknown"
# redistributable  = false
# sha256           = ""
# citation         = ""
# phi_reviewed     = true
# tolerant_regions = []

# [[slide]]
# name             = "dicom_wsi_brightfield_he_typical"
# alias            = "dicom-wsi-001"
# path             = "/absolute/local/path/to/series-folder-or-file.dcm"
# format           = "dicom"
# codecs           = ["jpeg"]
# must_decode      = ["base"]
# source           = "local-private"
# license          = "unknown"
# redistributable  = false
# phi_reviewed     = true

# [[slide]]
# name             = "dicom_wsi_uncompressed_native"
